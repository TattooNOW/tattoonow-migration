              "name": "pageSize",
              "value": "1"
            }
          ]
        },
        "options": {}
      },
      "id": "find-existing",
      "name": "Find Existing Task",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [740, 300],
      "credentials": {
        "airtableTokenApi": {
          "id": "3qQl1blWZA3JeOfK",
          "name": "Airtable Personal Access Token account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const records = $input.first().json.records || [];\nconst prev = $('Parse Input').first().json;\n\n// Build updated Notes: preserve existing content, only update metadata comments\nfunction mergeNotes(existingNotes, pipelineStage, stageData) {\n  let notes = existingNotes || '';\n  // Update or append pipelineStage comment\n  if (notes.match(/<!-- pipelineStage: .*? -->/)) {\n    notes = notes.replace(/<!-- pipelineStage: .*? -->/, `<!-- pipelineStage: ${pipelineStage} -->`);\n  } else {\n    notes += `\\n<!-- pipelineStage: ${pipelineStage} -->`;\n  }\n  // Update or append stageData comment if provided\n  if (stageData) {\n    const dataStr = JSON.stringify(stageData);\n    if (notes.match(/<!-- stageData: .*? -->/)) {\n      notes = notes.replace(/<!-- stageData: .*? -->/, `<!-- stageData: ${dataStr} -->`);\n    } else {\n      notes += `\\n<!-- stageData: ${dataStr} -->`;\n    }\n  }\n  return notes.trim();\n}\n\nif (records.length > 0) {\n  const rec = records[0];\n  const existingNotes = rec.fields?.Notes || rec.fields?.notes || '';\n  const notesField = mergeNotes(existingNotes, prev.pipelineStage, prev.stageData);\n  return [{ json: { \n    action: 'update', \n    recordId: rec.id, \n    domain: prev.domain,\n    status: prev.status, \n    notesField,\n    taskName: prev.taskName,\n    timestamp: prev.timestamp\n  } }];\n} else {\n  const notesField = mergeNotes('', prev.pipelineStage, prev.stageData);\n  return [{ json: { \n    action: 'create', \n    recordId: null, \n    domain: prev.domain,\n    status: prev.status, \n    notesField,\n    taskName: prev.taskName,\n    timestamp: prev.timestamp\n  } }];\n}"
      },
      "id": "decide-action",
