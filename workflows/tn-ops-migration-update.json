    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst domain = body.domain;\nconst pipelineStage = body.status || 'Queued';\nconst stageData = body.stageData || null;\nconst timestamp = body.timestamp || new Date().toISOString();\n\nif (!domain) {\n  return [{ json: { success: false, error: 'Missing domain' } }];\n}\n\n// Map pipeline stages to Airtable-compatible Status values\nconst stageToStatus = {\n  'Queued': 'To Do',\n  'Pre-Check': 'In Progress',\n  'GHL Setup': 'In Progress',\n  'Content': 'In Progress',\n  'Testing': 'In Progress',\n  'Review': 'In Progress',\n  'DNS': 'In Progress',\n  'Live': 'Done',\n  'Issues': 'Blocked'\n};\nconst airtableStatus = stageToStatus[pipelineStage] || 'In Progress';\n\nreturn [{ json: { domain, status: airtableStatus, pipelineStage, stageData, taskName: `Migrate: ${domain}`, timestamp } }];"
      },
      "id": "parse-input",
      "name": "Parse Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [500, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.airtable.com/v0/apptbA8Mljf70CG24/tblBP4uzRGQBcBco9",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "airtableTokenApi",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "filterByFormula",
              "value": "=AND({Project}='GHL Website Migration', {Task}='{{ $json.taskName }}')"
            },
